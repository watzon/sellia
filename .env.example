# Environment variables for Sellia Docker deployment
# Copy this file to .env and customize as needed

# Server Configuration
SELLIA_HOST=0.0.0.0
SELLIA_PORT=3000
SELLIA_DOMAIN=yourdomain.com  # Optional: Set this for subdomain routing
SELLIA_ACME_ENABLED=false     # Set to true to enable Let's Encrypt SSL
SELLIA_ACME_EMAIL=admin@yourdomain.com
SELLIA_ACME_TEST=true         # Set to false for production SSL certificates